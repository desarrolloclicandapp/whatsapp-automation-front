VITE_API_URL=https://wa.waflow.ai
VITE_STRIPE_PUBLIC_KEY=pk_live_replace_me
VITE_INSTALL_APP_URL=https://app.gohighlevel.com/integration/replace_me
VITE_SUPPORT_PHONE=595984756159

# Runtime switch for the official WhatsApp API UI.
# In Easypanel, set this in the frontend service environment and redeploy/restart.
VITE_OFFICIAL_WHATSAPP_API_UI_ENABLED=true

# Temporary internal testing bypass. Keep false in broad production rollout.
# When true, direct admins and admin impersonation sessions can open the
# official API setup even if the account does not already have an official
# Meta number configured.
VITE_OFFICIAL_WHATSAPP_API_ADMIN_BYPASS_ENABLED=false

# New agency UI canary. Both controls are required; an empty allowlist keeps
# every agency on the current production UI.
VITE_AGENCY_UI_V2_ENABLED=false
VITE_AGENCY_UI_V2_ALLOWLIST=
